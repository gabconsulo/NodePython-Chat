GATEWAY_PORT=8080
CHAT_SERVICE_PORT=8081
MODERATION_PORT=8082

CHAT_SERVICE_URL=http://chat-service:8081
MODERATION_SERVICE_URL=http://moderation-service:8082

GATEWAY_REQUEST_TIMEOUT_MS=5000
GATEWAY_MAX_RETRIES=2
MODERATION_REQUEST_TIMEOUT_SECONDS=1
MODERATION_MAX_RETRIES=2
ALLOW_DEGRADED_WRITES=true
MAX_MESSAGE_LENGTH=280
BLOCKED_TERMS=spam,ofensa,palavrao
CHAT_DB_PATH=/data/chat.db
